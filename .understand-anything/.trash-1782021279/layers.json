      "file:src/tools/__init__.py"
    ]
  },
  {
    "id": "layer:commit",
    "name": "提交层",
    "description": "SVN 版本提交子系统，封装 svn update/commit/revert 命令以及冲突检测、行级补丁应用和 diff 生成等文件变更管理能力。",
    "nodeIds": [
      "file:src/commit/svn.py",
      "file:src/commit/patcher.py",
      "file:src/commit/__init__.py"
