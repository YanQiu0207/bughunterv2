[
  {
    "id": "layer:entry",
    "name": "入口层",
    "description": "面向用户的命令行入口脚本（diagnose.py、fix.py、commit_fix.py），负责读取配置和输入、驱动完整的诊断或修复流程，以及 Python 包初始化文件。",
    "nodeIds": [
      "file:diagnose.py",
      "file:fix.py",
      "file:commit_fix.py",
      "file:src/__init__.py"
    ]
  },
  {
    "id": "layer:agent",
    "name": "Agent 层",
    "description": "基于 LangGraph/LangChain 实现的 DiagnosisAgent 和 FixAgent，包含对应的系统提示词模板，负责编排 LLM ReAct 推理循环与工具调用策略。",
    "nodeIds": [
      "file:src/agent/diagnosis_agent.py",
      "file:src/agent/fix_agent.py",
      "file:src/agent/prompts.py",
