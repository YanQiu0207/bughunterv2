      "file:src/agent/__init__.py"
    ]
  },
  {
    "id": "layer:tools",
    "name": "工具层",
    "description": "供 Agent 调用的 LangChain 工具封装，涵盖 Java 源码读取、调用方查找、代码修复应用、Maven 构建和测试执行，以及底层 shell 命令执行器。",
    "nodeIds": [
      "file:src/tools/read_source.py",
      "file:src/tools/find_callers.py",
      "file:src/tools/apply_fix.py",
